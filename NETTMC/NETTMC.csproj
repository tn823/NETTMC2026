<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>logoSamho.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Config\DefaultProgram.txt" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Config\DefaultProgram.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="logoSamho.ico" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\ConnectionClass\ConnectionClass.csproj" />
    <ProjectReference Include="..\GlobalFunction\GlobalFunction.csproj" />
    <ProjectReference Include="..\NetTMCVersion\NetTMCVersion.csproj" />
    <ProjectReference Include="..\QIP\QIP.csproj" />
    <ProjectReference Include="..\SystemControl\SystemControl.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Properties\Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Properties\Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

</Project>